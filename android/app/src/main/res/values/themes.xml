<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.WarehouseScanner" parent="Theme.MaterialComponents.DayNight">
        <item name="colorPrimary">@color/navy</item>
        <item name="colorPrimaryVariant">@color/navy_dark</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/orange</item>
        <item name="colorSecondaryVariant">@color/orange_dark</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="actionBarStyle">@style/WarehouseActionBar</item>
        <item name="android:navigationBarColor">@color/navy</item>
        <item name="textInputStyle">@style/WarehouseTextInput</item>
    </style>

    <style name="Theme.WarehouseScanner.NoActionBar" parent="Theme.WarehouseScanner">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.WarehouseScanner.Splash" parent="Theme.WarehouseScanner.NoActionBar">
        <item name="android:windowBackground">@color/navy</item>
    </style>

    <style name="WarehouseActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/navy</item>
        <item name="titleTextStyle">@style/WarehouseActionBarTitle</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="WarehouseActionBarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="WarehouseTextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/navy</item>
        <item name="hintTextColor">@color/navy</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
    </style>

    <style name="WarehouseButton.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/navy</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="WarehouseButton.Secondary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/orange</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="WarehouseButton.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">8dp</item>
        <item name="strokeColor">@color/orange</item>
        <item name="android:textColor">@color/orange</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
    </style>
</resources>
