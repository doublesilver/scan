<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_container_low">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 상품명 헤더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:paddingStart="52dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvProductMasterName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:maxLines="3"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- 스크롤 콘텐츠 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <!-- ROW 1: 구역 위치 + 세부 위치 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <!-- 블록1: 구역 위치 -->
                    <LinearLayout
                        android:id="@+id/blockZonePhoto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/bg_block_border"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/tvZoneTag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_location_tag"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface"
                            android:text="구역" />

                        <ImageView
                            android:id="@+id/ivZonePhoto"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:layout_marginTop="6dp"
                            android:scaleType="centerCrop"
                            android:background="@drawable/bg_photo_placeholder"
                            android:src="@drawable/ic_placeholder"
                            android:contentDescription="구역 사진" />
                    </LinearLayout>

                    <!-- 블록2: 세부 위치 -->
                    <LinearLayout
                        android:id="@+id/blockShelfPhoto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_block_border"
                        android:orientation="vertical"
                        android:padding="8dp">

                        <TextView
                            android:id="@+id/tvShelfTag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_location_tag"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface"
                            android:text="위치" />

                        <ImageView
                            android:id="@+id/ivShelfPhoto"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:layout_marginTop="6dp"
                            android:scaleType="centerCrop"
                            android:background="@drawable/bg_photo_placeholder"
                            android:src="@drawable/ic_placeholder"
                            android:contentDescription="선반 사진" />
                    </LinearLayout>

                </LinearLayout>

                <!-- ROW 2: 도면 + 옵션 이미지 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <!-- 블록3: 도면 인라인 -->
                    <FrameLayout
                        android:id="@+id/blockMap"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/bg_block_border"
                        android:minHeight="160dp"
                        android:padding="8dp">

                        <LinearLayout
                            android:id="@+id/layoutInlineMap"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center" />

                    </FrameLayout>

                    <!-- 블록4: 한국 옵션 이미지 (세로 스크롤) -->
                    <ScrollView
                        android:id="@+id/blockOptionImages"
                        android:layout_width="0dp"
                        android:layout_height="200dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_block_border"
                        android:padding="8dp">

                        <LinearLayout
                            android:id="@+id/layoutOptionImages"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />

                    </ScrollView>

                </LinearLayout>

                <!-- ROW 3: 발주 이미지 + 외부 링크 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <!-- 블록5: 발주 중국 옵션 이미지 (세로 스크롤) -->
                    <ScrollView
                        android:id="@+id/blockSourcingImages"
                        android:layout_width="0dp"
                        android:layout_height="200dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/bg_block_border"
                        android:padding="8dp">

                        <LinearLayout
                            android:id="@+id/layoutSourcingImages"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvSourcingPlaceholder"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="발주 중국\n옵션 이미지"
                                android:textSize="13sp"
                                android:textColor="@color/on_surface_variant"
                                android:gravity="center"
                                android:layout_gravity="center"
                                android:layout_marginTop="60dp" />

                        </LinearLayout>

                    </ScrollView>

                    <!-- 블록6: 외부 링크 버튼 -->
                    <LinearLayout
                        android:id="@+id/blockLinks"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:orientation="vertical">

                        <!-- 링크 1행: N + 쿠팡 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                            <FrameLayout
                                android:id="@+id/btnNaver"
                                android:layout_width="0dp"
                                android:layout_height="80dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp"
                                android:background="@drawable/bg_link_button"
                                android:foreground="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="N"
                                    android:textSize="28sp"
                                    android:textStyle="bold"
                                    android:textColor="#1EC800" />
                            </FrameLayout>

                            <FrameLayout
                                android:id="@+id/btnCoupang"
                                android:layout_width="0dp"
                                android:layout_height="80dp"
                                android:layout_weight="1"
                                android:layout_marginStart="4dp"
                                android:background="@drawable/bg_link_button"
                                android:foreground="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="🚀"
                                    android:textSize="28sp" />
                            </FrameLayout>

                        </LinearLayout>

                        <!-- 링크 2행: 1688 + FLOW -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <FrameLayout
                                android:id="@+id/btn1688"
                                android:layout_width="0dp"
                                android:layout_height="80dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="4dp"
                                android:background="@drawable/bg_link_button"
                                android:foreground="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="1688"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:textColor="#FF6A00" />
                            </FrameLayout>

                            <FrameLayout
                                android:id="@+id/btnFlow"
                                android:layout_width="0dp"
                                android:layout_height="80dp"
                                android:layout_weight="1"
                                android:layout_marginStart="4dp"
                                android:background="@drawable/bg_link_button"
                                android:foreground="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:text="FLOW"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:textColor="#6C5CE7" />
                            </FrameLayout>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

        <!-- 하단 바: 도면 / 구매하기 / 인쇄 -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/primary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBarMap"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="도면"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_map"
                app:iconGravity="top"
                app:iconTint="@android:color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBarBuy"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="구매하기"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_shopping_cart"
                app:iconGravity="top"
                app:iconTint="@android:color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBarPrint"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:text="인쇄"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_print"
                app:iconGravity="top"
                app:iconTint="@android:color/white" />

        </LinearLayout>

    </LinearLayout>

    <!-- 뒤로가기 오버레이 -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="start|top"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_back_button"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="뒤로가기"
        android:scaleType="centerInside"
        android:padding="10dp" />

</FrameLayout>
